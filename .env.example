# sliderule Application Configuration
# Copy this file to .env.local and update values as needed

# ====== Database URLs ======
# Citus (PostgreSQL with distributed tables extension)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sliderule

# CockroachDB (PostgreSQL-compatible distributed SQL)
DATABASE_URL_COCKROACH=postgresql://root@localhost:26257/sliderule?sslmode=disable

# ====== OpenTelemetry / Observability ======
# Enable OpenTelemetry logs export
OTEL_LOGS_ENABLED=true

# OTLP (OpenTelemetry Protocol) endpoint for logs
# Default: Grafana Loki collector at port 4319
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4319

# OTLP gRPC endpoint for traces (Tempo)
# Used by OpenTelemetry SDK
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ====== Server Configuration ======
# API host (default: localhost for development)
API_HOST=127.0.0.1

# Citus API port
CITUS_API_PORT=8000

# CockroachDB API port
COCKROACHDB_API_PORT=8001

# ====== Python Paths ======
# Set automatically by scripts/setup.sh and scripts/start.sh
# PYTHONPATH should point to repository root
